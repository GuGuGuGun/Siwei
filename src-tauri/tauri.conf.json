{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Siwei",
  "version": "0.10.0",
  "identifier": "com.gugugugun.siwei",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Siwei",
        "width": 1000,
        "height": 720
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"],
    "externalBin": [
      "binaries/siwei-pi-agent-sidecar",
      "binaries/siwei-node-runtime"
    ],
    "resources": {
      "../sidecars/siwei-pi-agent-sidecar.mjs": "sidecars/siwei-pi-agent-sidecar.mjs",
      "../node_modules": "node_modules"
    }
  }
}
